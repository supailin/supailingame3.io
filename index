<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>อัตราการเกิดของประเทศไทย</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Sarabun', sans-serif;
    background: #0a0e1a;
    color: #e8eaf0;
    min-height: 100vh;
    padding: 32px 24px;
    position: relative;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 80%;
    background: radial-gradient(ellipse, rgba(255,80,60,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  body::after {
    content: '';
    position: fixed;
    bottom: -30%;
    right: -10%;
    width: 50%;
    height: 70%;
    background: radial-gradient(ellipse, rgba(40,120,255,0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 40px;
    border-left: 3px solid #ff4e3a;
    padding-left: 20px;
  }

  .label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    color: #ff4e3a;
    text-transform: uppercase;
    margin-bottom: 10px;
    opacity: 0.85;
  }

  h1 {
    font-size: clamp(22px, 4vw, 34px);
    font-weight: 700;
    line-height: 1.2;
    color: #f0f2fa;
    margin-bottom: 8px;
  }

  .subtitle {
    font-size: 14px;
    color: #7a8099;
    font-weight: 300;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .stat-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 18px 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .stat-card:hover { border-color: rgba(255,78,58,0.3); }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, #ff4e3a, transparent);
  }

  .stat-label {
    font-size: 11px;
    color: #6a7090;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    font-family: 'IBM Plex Mono', monospace;
  }

  .stat-value {
    font-size: 26px;
    font-weight: 700;
    color: #f0f2fa;
    font-family: 'IBM Plex Mono', monospace;
    line-height: 1;
  }

  .stat-sub {
    font-size: 12px;
    color: #7a8099;
    margin-top: 5px;
  }

  .stat-value.red { color: #ff4e3a; }
  .stat-value.green { color: #3de0a0; }
  .stat-value.blue { color: #4ea8ff; }

  .chart-wrapper {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 28px 24px 20px;
    margin-bottom: 24px;
    position: relative;
  }

  .chart-title {
    font-size: 13px;
    font-weight: 600;
    color: #c0c5d8;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .chart-title span {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #ff4e3a;
    display: inline-block;
  }

  .chart-title span.blue { background: #4ea8ff; }

  canvas { width: 100% !important; }

  .note-box {
    background: rgba(255,78,58,0.06);
    border: 1px solid rgba(255,78,58,0.2);
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 20px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .note-icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }

  .note-text {
    font-size: 13.5px;
    line-height: 1.7;
    color: #c0c5d8;
  }

  .note-text strong { color: #ff4e3a; }

  .source {
    font-size: 11px;
    color: #3a3f55;
    font-family: 'IBM Plex Mono', monospace;
    text-align: right;
    margin-top: 8px;
  }
</style>
</head>
<body>
<div class="container">

  <header>
    <div class="label">📊 ข้อมูลประชากรศาสตร์ · Thailand</div>
    <h1>อัตราการเกิดของประเทศไทย</h1>
    <p class="subtitle">จำนวนเด็กเกิดใหม่ต่อประชากร 1,000 คน และจำนวนเด็กเกิดใหม่รายปี (ค.ศ. 1960–2024)</p>
  </header>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-label">ปี ค.ศ. 1960</div>
      <div class="stat-value blue">43.7</div>
      <div class="stat-sub">เด็กเกิด/ประชากร 1,000 คน</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">ปี ค.ศ. 2024</div>
      <div class="stat-value red">6.8</div>
      <div class="stat-sub">เด็กเกิด/ประชากร 1,000 คน</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">จำนวนเด็กเกิด 2567</div>
      <div class="stat-value red">462K</div>
      <div class="stat-sub">ต่ำสุดในรอบ 75 ปี</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">TFR ปี 2567</div>
      <div class="stat-value red">1.0</div>
      <div class="stat-sub">ต่ำกว่าระดับทดแทน 2.1</div>
    </div>
  </div>

  <div class="note-box">
    <div class="note-icon">⚠️</div>
    <div class="note-text">
      ปี 2567 ถือเป็น <strong>ก้าวประวัติศาสตร์</strong> ที่จำนวนเด็กเกิดใหม่ต่ำกว่า 500,000 คนเป็นครั้งแรกในรอบ 75 ปี และไทยเป็น <strong>"ตายมากกว่าเกิด"</strong> ต่อเนื่องตั้งแต่ปี 2564 ทำให้จำนวนประชากรรวมเริ่มหดตัว ปัจจุบันไทยมีประชากร 65.8 ล้านคน
    </div>
  </div>

  <div class="chart-wrapper">
    <div class="chart-title"><span></span> อัตราการเกิดหยาบ (Crude Birth Rate) ต่อประชากร 1,000 คน</div>
    <canvas id="cbrChart" height="300"></canvas>
  </div>

  <div class="chart-wrapper">
    <div class="chart-title"><span class="blue"></span> จำนวนเด็กเกิดมีชีพต่อปี (หน่วย: พันคน)</div>
    <canvas id="birthsChart" height="280"></canvas>
  </div>

  <div class="chart-wrapper">
    <div class="chart-title"><span></span> อัตราเจริญพันธุ์รวม (TFR) — จำนวนบุตรเฉลี่ยต่อผู้หญิง 1 คน</div>
    <canvas id="tfrChart" height="260"></canvas>
  </div>

  <div class="source">แหล่งข้อมูล: World Bank · สถาบันวิจัยประชากรและสังคม ม.มหิดล · กรมการปกครอง · Wikipedia Demographics of Thailand</div>
</div>

<script>
const years = [1960,1965,1970,1975,1980,1985,1990,1995,2000,2005,2010,2015,2019,2020,2021,2022,2023,2024];

// Crude Birth Rate per 1000 population
const cbr = [43.7, 41.9, 38.9, 34.0, 27.5, 22.7, 19.8, 17.0, 15.3, 13.4, 11.8, 10.5, 9.8, 9.5, 8.5, 8.2, 7.9, 6.8];

// Births (thousands)
const births_data = [
  {year: 1960, val: 630},
  {year: 1970, val: 820},
  {year: 1980, val: 850},
  {year: 1990, val: 780},
  {year: 2000, val: 700},
  {year: 2005, val: 660},
  {year: 2010, val: 740},
  {year: 2015, val: 710},
  {year: 2019, val: 604},
  {year: 2020, val: 548},
  {year: 2021, val: 544},
  {year: 2022, val: 485},
  {year: 2023, val: 519},
  {year: 2024, val: 462},
];

// TFR
const tfr_data = [
  {year: 1960, val: 6.1},
  {year: 1965, val: 5.9},
  {year: 1970, val: 5.5},
  {year: 1975, val: 4.6},
  {year: 1980, val: 3.4},
  {year: 1985, val: 2.7},
  {year: 1990, val: 2.1},
  {year: 1995, val: 1.8},
  {year: 2000, val: 1.7},
  {year: 2005, val: 1.5},
  {year: 2010, val: 1.5},
  {year: 2015, val: 1.5},
  {year: 2019, val: 1.3},
  {year: 2020, val: 1.3},
  {year: 2021, val: 1.3},
  {year: 2022, val: 1.22},
  {year: 2023, val: 1.21},
  {year: 2024, val: 1.0},
];

const gridColor = 'rgba(255,255,255,0.05)';
const tickColor = '#6a7090';

Chart.defaults.color = tickColor;
Chart.defaults.font.family = "'Sarabun', sans-serif";
Chart.defaults.font.size = 12;

// ─── CBR Chart ───────────────────────────────────────
const cbrCtx = document.getElementById('cbrChart').getContext('2d');
const cbrGrad = cbrCtx.createLinearGradient(0, 0, 0, 320);
cbrGrad.addColorStop(0, 'rgba(255,78,58,0.28)');
cbrGrad.addColorStop(1, 'rgba(255,78,58,0)');

new Chart(cbrCtx, {
  type: 'line',
  data: {
    labels: years,
    datasets: [{
      label: 'CBR (ต่อ 1,000 คน)',
      data: cbr,
      borderColor: '#ff4e3a',
      backgroundColor: cbrGrad,
      borderWidth: 2.5,
      pointRadius: 4,
      pointBackgroundColor: '#ff4e3a',
      pointBorderColor: '#0a0e1a',
      pointBorderWidth: 2,
      tension: 0.4,
      fill: true,
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: { display: false },
      tooltip: {
        backgroundColor: '#13172a',
        borderColor: 'rgba(255,78,58,0.3)',
        borderWidth: 1,
        titleColor: '#ff4e3a',
        bodyColor: '#c0c5d8',
        padding: 12,
        callbacks: {
          label: ctx => `  ${ctx.parsed.y} เด็กเกิด / 1,000 คน`
        }
      }
    },
    scales: {
      x: {
        grid: { color: gridColor },
        ticks: { color: tickColor }
      },
      y: {
        grid: { color: gridColor },
        ticks: { color: tickColor },
        title: { display: true, text: 'ต่อประชากร 1,000 คน', color: '#5a6080' }
      }
    }
  }
});

// ─── Births Chart ─────────────────────────────────────
const bCtx = document.getElementById('birthsChart').getContext('2d');
const bGrad = bCtx.createLinearGradient(0, 0, 0, 300);
bGrad.addColorStop(0, 'rgba(78,168,255,0.22)');
bGrad.addColorStop(1, 'rgba(78,168,255,0)');

new Chart(bCtx, {
  type: 'bar',
  data: {
    labels: births_data.map(d => d.year),
    datasets: [{
      label: 'จำนวนเด็กเกิด (พันคน)',
      data: births_data.map(d => d.val),
      backgroundColor: births_data.map(d =>
        d.year >= 2021 ? 'rgba(255,78,58,0.7)' : 'rgba(78,168,255,0.55)'
      ),
      borderColor: births_data.map(d =>
        d.year >= 2021 ? '#ff4e3a' : '#4ea8ff'
      ),
      borderWidth: 1.5,
      borderRadius: 5,
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: { display: false },
      tooltip: {
        backgroundColor: '#13172a',
        borderColor: 'rgba(78,168,255,0.3)',
        borderWidth: 1,
        titleColor: '#4ea8ff',
        bodyColor: '#c0c5d8',
        padding: 12,
        callbacks: {
          label: ctx => `  ${ctx.parsed.y.toLocaleString()} พันคน`
        }
      }
    },
    scales: {
      x: { grid: { color: gridColor }, ticks: { color: tickColor } },
      y: {
        grid: { color: gridColor },
        ticks: { color: tickColor },
        title: { display: true, text: 'พันคน', color: '#5a6080' }
      }
    }
  }
});

// ─── TFR Chart ────────────────────────────────────────
const tCtx = document.getElementById('tfrChart').getContext('2d');
const tGrad = tCtx.createLinearGradient(0, 0, 0, 280);
tGrad.addColorStop(0, 'rgba(61,224,160,0.2)');
tGrad.addColorStop(1, 'rgba(61,224,160,0)');

new Chart(tCtx, {
  type: 'line',
  data: {
    labels: tfr_data.map(d => d.year),
    datasets: [
      {
        label: 'TFR',
        data: tfr_data.map(d => d.val),
        borderColor: '#3de0a0',
        backgroundColor: tGrad,
        borderWidth: 2.5,
        pointRadius: 4,
        pointBackgroundColor: '#3de0a0',
        pointBorderColor: '#0a0e1a',
        pointBorderWidth: 2,
        tension: 0.4,
        fill: true,
      },
      {
        label: 'ระดับทดแทน 2.1',
        data: tfr_data.map(() => 2.1),
        borderColor: 'rgba(255,200,50,0.5)',
        borderWidth: 1.5,
        borderDash: [6, 4],
        pointRadius: 0,
        fill: false,
      }
    ]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {
        display: true,
        labels: { color: '#7a8099', usePointStyle: true, boxWidth: 10 }
      },
      tooltip: {
        backgroundColor: '#13172a',
        borderColor: 'rgba(61,224,160,0.3)',
        borderWidth: 1,
        titleColor: '#3de0a0',
        bodyColor: '#c0c5d8',
        padding: 12,
      }
    },
    scales: {
      x: { grid: { color: gridColor }, ticks: { color: tickColor } },
      y: {
        grid: { color: gridColor },
        ticks: { color: tickColor },
        title: { display: true, text: 'บุตรเฉลี่ยต่อผู้หญิง 1 คน', color: '#5a6080' },
        min: 0, max: 7
      }
    }
  }
});
</script>
</body>
</html>
